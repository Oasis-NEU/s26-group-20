PORT=8000

# Required: your Supabase project URL
# Example: https://xyzcompany.supabase.co
SUPABASE_URL=
# Also accepted by backend (for compatibility with Next.js projects):
NEXT_PUBLIC_SUPABASE_URL=

# Backend key preference (first found is used):
# 1) SUPABASE_SECRET_KEY (recommended for trusted backend server code)
# 2) SUPABASE_SERVICE_ROLE_KEY (legacy naming)
# 3) SUPABASE_KEY / SUPABASE_PUBLISHABLE_KEY (not recommended for admin backend operations)
# 4) NEXT_PUBLIC_SUPABASE_ANON_KEY (read-only scenarios; health check still works)
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
